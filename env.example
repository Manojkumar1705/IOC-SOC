# =============================================================
#  IOC Aggregator — Environment Configuration
#  Copy this file to .env and fill in your API keys
#  NEVER commit .env to GitHub
# =============================================================

# ── API Keys ──────────────────────────────────────────────────
# OTX AlienVault — https://otx.alienvault.com
OTX_API_KEY=your_otx_key_here

# Malshare — https://malshare.com
MALSHARE_API_KEY=your_malshare_key_here

# Pulsedive — https://pulsedive.com
PULSEDIVE_API_KEY=your_pulsedive_key_here

# Abuse.ch (covers both ThreatFox + MalwareBazaar) — https://auth.abuse.ch
ABUSECH_API_KEY=your_abusech_key_here

# VirusTotal — https://www.virustotal.com
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# AbuseIPDB — https://www.abuseipdb.com
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# HybridAnalysis — https://www.hybrid-analysis.com
HYBRIDANALYSIS_API_KEY=your_hybridanalysis_key_here

# ── Optional Settings ─────────────────────────────────────────
# Output directory for generated CSV files (default: output)
OUTPUT_DIR=output

# State directory for deduplication persistence (default: state)
STATE_DIR=state

# HTTP request timeout in seconds (default: 30)
REQUEST_TIMEOUT=30
